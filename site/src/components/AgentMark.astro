---
import claudeMark from '../assets/brands/claude.svg?raw';
import codexMark from '../assets/brands/codex.svg?raw';

interface Props {
  agent: 'claude' | 'grok' | 'codex';
  showName?: boolean;
}

const { agent, showName = true } = Astro.props;
const names = {
  claude: 'Claude Code',
  grok: 'Grok Build',
  codex: 'Codex',
} as const;
const marks = {
  claude: claudeMark,
  codex: codexMark,
} as const;
const mark = agent === 'claude' ? marks.claude : marks.codex;
---

<span class="agent-mark" data-agent={agent} aria-label={names[agent]}>
  {
    agent === 'grok' ? (
      <span class="agent-grok" aria-hidden="true">GROK</span>
    ) : (
      <span class="agent-icon" aria-hidden="true" set:html={mark} />
    )
  }
  {showName && <span class="agent-name">{names[agent]}</span>}
</span>

<style>
  .agent-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.65em;
    min-width: 0;
    color: var(--text);
  }

  .agent-icon {
    display: inline-flex;
    width: 1.35em;
    height: 1.35em;
    flex: none;
  }

  .agent-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .agent-grok {
    display: inline-grid;
    place-items: center;
    min-width: 2.7em;
    height: 1.35em;
    font-family: var(--font-display);
    font-size: 0.86em;
    line-height: 1;
    letter-spacing: 0.06em;
  }

  .agent-name {
    font-size: 0.92em;
    font-weight: 600;
    white-space: nowrap;
  }
</style>
