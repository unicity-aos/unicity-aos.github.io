---
/**
 * Decorative background ornament: a dense radial burst of thin dashes,
 * events radiating from the kernel at the (empty) centre. Two depth layers:
 * a soft blurred field behind, a near-sharp field in front, both drifting
 * slowly in opposite directions. Deterministic (seeded, not Math.random) so
 * builds are reproducible. Pure SVG + CSS, no script, aria-hidden; the
 * drift stops under prefers-reduced-motion.
 */
const rand = (i: number, salt: number): number => {
  const x = Math.sin(i * 127.1 + salt * 311.7) * 43758.5453;
  return x - Math.floor(x);
};

// Mostly capsule-purple, with bus-teal, audit-pink, and plain-light accents.
const palette = [
  'var(--capsule)',
  'var(--capsule)',
  'var(--capsule)',
  'var(--bus)',
  'var(--capsule)',
  'var(--audit)',
  'var(--text-dim)',
  'var(--bus)',
];

interface Dash {
  angle: number;
  r: number;
  len: number;
  w: number;
  fill: string;
  opacity: number;
}

function burst(count: number, salt: number, rMin: number, rMax: number): Dash[] {
  return Array.from({ length: count }, (_, i) => {
    const r = rMin + rand(i, salt + 1) * (rMax - rMin);
    // Longer dashes stay near the rim so the centre keeps its void.
    const len = 26 + rand(i, salt + 2) * 130 * ((r - rMin) / (rMax - rMin) * 0.7 + 0.3);
    return {
      angle: rand(i, salt) * 360,
      r,
      len,
      w: 3 + rand(i, salt + 3) * 4.5,
      fill: palette[Math.floor(rand(i, salt + 4) * palette.length)],
      opacity: 0.24 + rand(i, salt + 5) * 0.55,
    };
  });
}

const back = burst(150, 7, 115, 268);
const front = burst(170, 23, 130, 255);
---

<div class="ring-wrap" aria-hidden="true">
  <svg class="ring" viewBox="0 0 600 600">
    <g class="layer layer-back">
      {
        back.map((d) => (
          <rect
            x={300 + d.r}
            y={300 - d.w / 2}
            width={d.len}
            height={d.w}
            rx={d.w / 2}
            fill={d.fill}
            opacity={d.opacity * 0.75}
            transform={`rotate(${d.angle} 300 300)`}
          />
        ))
      }
    </g>
    <g class="layer layer-front">
      {
        front.map((d) => (
          <rect
            x={300 + d.r}
            y={300 - d.w / 2}
            width={d.len}
            height={d.w}
            rx={d.w / 2}
            fill={d.fill}
            opacity={d.opacity}
            transform={`rotate(${d.angle} 300 300)`}
          />
        ))
      }
    </g>
  </svg>
</div>

<style>
  .ring-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .ring {
    position: absolute;
    top: 50%;
    left: 72%;
    width: min(96vmin, 62rem);
    aspect-ratio: 1;
    translate: -50% -50%;
    /* fade the burst out toward its own edge so it never hard-crops */
    mask-image: radial-gradient(circle, black 58%, transparent 80%);
  }

  .layer {
    transform-origin: 300px 300px;
  }

  .layer-back {
    filter: blur(8px);
    animation: ring-drift 240s linear infinite;
  }

  .layer-front {
    animation: ring-drift 320s linear infinite reverse;
  }

  @keyframes ring-drift {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .layer {
      animation: none;
    }
  }

  @media (max-width: 900px) {
    .ring {
      left: 50%;
      opacity: 0.5;
    }
  }
</style>
