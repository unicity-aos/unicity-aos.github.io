---
/** Section 7 — the books. Two spines; phase 2 wires the routes. */
---

<section class="books hairline-top" id="books" data-scene>
  <div class="wrap">
    <p class="eyebrow">06 · go deeper</p>
    <h2 class="books-title">The library ships with the OS.</h2>
    <div class="books-grid">
      <a class="book-card card" href="/book/">
        <span class="book-spine" data-book aria-hidden="true"></span>
        <div class="book-meta">
          <h3>The Astrid Book</h3>
          <p class="dim">
            The canonical deep dive: the capsule model, the host ABI, the bus,
            the five-layer gate, storage, identity, distribution. For engineers
            who want to know exactly how the machine works.
          </p>
          <p class="mono book-tag">36 chapters · grounded in code</p>
        </div>
      </a>
      <a class="book-card card" href="/handbook/">
        <span class="book-spine" data-handbook aria-hidden="true"></span>
        <div class="book-meta">
          <h3>The Contributor Handbook</h3>
          <p class="dim">
            Operational law for people working on Astrid itself: the polyrepo,
            the kernel-is-dumb rule, the RFC trigger, contribution tiers, and
            the release process.
          </p>
          <p class="mono book-tag">the rules of the road</p>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .books {
    padding-block: var(--s-8);
  }

  .books-title {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-5);
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: var(--s-3);
  }

  .book-card {
    display: flex;
    gap: var(--s-3);
    padding: var(--s-3);
    color: inherit;
    transition: border-color var(--t-med) var(--ease-out), transform var(--t-med) var(--ease-out);
  }

  .book-card:hover {
    text-decoration: none;
    border-color: var(--line-bright);
    transform: translateY(-3px);
  }

  .book-spine {
    flex: none;
    width: 3.2rem;
    border-radius: 6px 10px 10px 6px;
    border: 1px solid var(--line-bright);
    background:
      linear-gradient(to right, rgb(255 255 255 / 8%), transparent 30%),
      var(--aurora);
  }

  .book-card[href='/handbook/'] .book-spine {
    background:
      linear-gradient(to right, rgb(255 255 255 / 8%), transparent 30%),
      linear-gradient(160deg, #f472b6, #a78bfa);
  }

  .book-meta h3 {
    font-size: var(--step-1);
    margin-bottom: 0.4em;
  }

  .book-meta .dim {
    font-size: var(--step--1);
    margin-bottom: 0.8em;
  }

  .book-tag {
    font-size: 0.72rem;
    color: var(--text-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
