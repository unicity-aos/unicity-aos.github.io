---
/** Section 3 — "Everything else is a capsule."
 *  The capsules clamp onto the rail one by one as they scroll into view;
 *  each chip carries a real topic path from the bus registry. */
const capsules = [
  { name: 'provider', topic: 'prompt_builder.v1.hook.before_build' },
  { name: 'agent loop', topic: 'react.v1.loop.step' },
  { name: 'tools', topic: 'tool.v1.request.describe' },
  { name: 'memory', topic: 'memory.v1.recall' },
  { name: 'session', topic: 'session.v1.thread.append' },
  { name: 'skills', topic: 'skills.v1.list' },
];
---

<section class="scene wrap" id="capsules" data-scene>
  <div class="capsule-rack">
    {
      capsules.map((c) => (
        <div class="capsule-row">
          <span class="dock-chip" data-dock={c.name}>{c.name}</span>
          <code class="topic">{c.topic}</code>
        </div>
      ))
    }
  </div>
  <div class="scene-copy prose">
    <p class="eyebrow">02 · capsule-space</p>
    <h2>Everything else<br />is a <span class="capsule-word">capsule</span>.</h2>
    <p>
      The model provider. The agent loop. Every tool, the memory, the
      frontends. Each one is a WebAssembly process with a manifest, typed IPC,
      and zero ambient authority — clamped onto the rail, never inside it.
    </p>
    <p>
      Swap the provider and the same agent runs against a hosted frontier
      model today, a local one tomorrow. Swap the loop and a debate protocol
      or an overnight autonomous worker is something you write, not a
      framework you fork. The same core OS becomes a different machine.
    </p>
  </div>
</section>

<style>
  .scene {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
    gap: var(--s-5);
    align-items: center;
    padding-block: var(--s-8);
  }

  @media (max-width: 900px) {
    .scene {
      grid-template-columns: 1fr;
    }

    .capsule-rack {
      order: 2;
    }
  }

  .scene-copy h2 {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-3);
  }

  .scene-copy p + p {
    margin-top: var(--s-2);
  }

  .capsule-word {
    color: var(--capsule);
  }

  .capsule-rack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-3);
  }

  .capsule-row {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    min-width: 0;
  }

  .topic {
    font-size: 0.7rem;
    color: var(--text-faint);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 620px) {
    .topic {
      display: none;
    }
  }
</style>
