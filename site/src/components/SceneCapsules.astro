---
/** Section 3 — "Everything else is a capsule."
 *  Scroll docks the capsules one by one around the core; topic paths from the
 *  real registry light up in the caption strip. */
const topics = [
  'prompt_builder.v1.hook.before_build',
  'tool.v1.request.describe',
  'session.v1.thread.append',
  'react.v1.loop.step',
];
---

<section class="scene wrap scene-rev" id="capsules" data-scene data-capsule-scene>
  <div class="scene-stage card">
    <astrid-bus mode="capsules" id="capsule-bus" docked="0"></astrid-bus>
    <p class="topics mono" aria-hidden="true">
      {topics.map((t) => <span class="topic">{t}</span>)}
    </p>
  </div>
  <div class="scene-copy prose">
    <p class="eyebrow">02 · capsule-space</p>
    <h2>Everything else<br />is a <span class="capsule-word">capsule</span>.</h2>
    <p>
      The model provider. The agent loop. Every tool, the memory, the
      frontends. Each one is a WebAssembly process with a manifest, typed IPC,
      and zero ambient authority.
    </p>
    <p>
      Swap the provider and the same agent runs against a hosted frontier
      model today, a local one tomorrow. Swap the loop and a debate protocol
      or an overnight autonomous worker is something you write, not a
      framework you fork. The same core OS becomes a different machine.
    </p>
  </div>
</section>

<style>
  .scene {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: var(--s-5);
    align-items: center;
    padding-block: var(--s-8);
  }

  @media (max-width: 900px) {
    .scene {
      grid-template-columns: 1fr;
    }

    .scene-rev .scene-stage {
      order: 2;
    }
  }

  .scene-copy h2 {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-3);
  }

  .scene-copy p + p {
    margin-top: var(--s-2);
  }

  .capsule-word {
    color: var(--capsule);
  }

  .scene-stage {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    position: relative;
  }

  .scene-stage astrid-bus {
    display: block;
    width: 100%;
    height: 100%;
  }

  .topics {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: flex;
    gap: var(--s-3);
    padding: var(--s-1) var(--s-2);
    overflow: hidden;
    white-space: nowrap;
    font-size: 0.7rem;
    color: var(--text-faint);
    border-top: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg) 60%, transparent);
  }

  .topic {
    opacity: 0.35;
    transition: opacity var(--t-med) var(--ease-out), color var(--t-med) var(--ease-out);
  }

  .topic[data-lit] {
    opacity: 1;
    color: var(--bus);
  }
</style>
