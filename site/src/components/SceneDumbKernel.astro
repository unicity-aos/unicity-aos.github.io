---
/** Section 2 — "The kernel is dumb. That is the point."
 *  The rail routes between endpoints that clamp on from the edges; a live
 *  demo publisher fires real publishes while the section is on screen, and
 *  every pulse on the rail is a real EventBus delivery. */
---

<section class="scene wrap" id="dumb-kernel" data-scene>
  <div class="scene-copy prose">
    <p class="eyebrow">01 · the rail</p>
    <h2>The kernel is dumb.<br />That is the point.</h2>
    <p>
      The Astrid kernel routes events, enforces capabilities, and runs the
      sandbox. Nothing else. No model, no business logic, no protocol parsers.
      Intelligence is a tenant, never a landlord: replacing how your agent
      thinks never means forking the OS it stands on.
    </p>
    <p>
      That thin line on the left is the whole kernel. Everything else on this
      page clamps onto it.
    </p>
    <p class="mono live-caption" id="dk-caption" hidden>
      each pulse riding the rail is a real EventBus delivery inside this tab —
      <span id="dk-count">0</span> so far in this scene
    </p>
  </div>
  <div class="endpoints" aria-hidden="true">
    <span class="dock-chip" data-dock="uplink"><span class="kind">uplink ·</span> cli</span>
    <span class="dock-chip" data-dock="uplink"><span class="kind">uplink ·</span> gateway</span>
    <span class="dock-chip" data-dock="uplink"><span class="kind">uplink ·</span> discord</span>
  </div>
</section>

<style>
  .scene {
    display: grid;
    grid-template-columns: minmax(0, 8fr) minmax(0, 4fr);
    gap: var(--s-5);
    align-items: center;
    padding-block: var(--s-8);
  }

  @media (max-width: 900px) {
    .scene {
      grid-template-columns: 1fr;
    }
  }

  .scene-copy h2 {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-3);
  }

  .scene-copy p + p {
    margin-top: var(--s-2);
  }

  .endpoints {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-4);
  }

  .live-caption {
    font-size: var(--step--1);
    color: var(--bus);
  }

  .live-caption span {
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  import { onKernel, kernel } from '../scripts/kernel';

  const caption = document.getElementById('dk-caption')!;
  const count = document.getElementById('dk-count')!;
  let seen = 0;
  let timer: number | undefined;

  // demo publisher: real publishes onto the real bus, only while visible
  const section = document.getElementById('dumb-kernel')!;
  const io = new IntersectionObserver((entries) => {
    const on = entries[0]?.isIntersecting ?? false;
    if (on && timer === undefined) {
      timer = window.setInterval(() => {
        const bridge = kernel();
        if (!bridge) return;
        void bridge.publish(
          'site.v1.demo.route',
          JSON.stringify({ scene: 'dumb-kernel', at: Date.now() }),
        );
      }, 2600);
    } else if (!on && timer !== undefined) {
      clearInterval(timer);
      timer = undefined;
    }
  });
  io.observe(section);

  onKernel((status, bridge) => {
    if (status !== 'online' || !bridge) return;
    caption.hidden = false;
    bridge.subscribe('site.v1.demo.*', () => {
      seen += 1;
      count.textContent = String(seen);
    });
  });
</script>
