---
/** Section 04a — the keys. The security model as a scroll story: you cut
 *  copies of your keys downward, each level gets fewer, and nothing below
 *  you can ever hold a key you don't. The section pins; each scroll-catch
 *  reveals one level of the hand-me-down chain. Pure function of scroll
 *  position (reversing the scroll reverses the story); reduced motion shows
 *  the finished chain with no pin. */

interface KeyDef {
  label: string;
  kind: 'plain' | 'held';
}

const KEY_ROWS: { who: string; note: string; keys: KeyDef[] }[] = [
  {
    who: 'You',
    note: 'You hold every key',
    keys: [
      { label: 'Your files', kind: 'plain' },
      { label: 'The web', kind: 'plain' },
      { label: 'Run commands', kind: 'plain' },
      { label: 'Your passwords', kind: 'held' },
    ],
  },
  {
    who: 'Your agent',
    note: 'Gets copies of three · your passwords: no copy, ever',
    keys: [
      { label: 'Your files', kind: 'plain' },
      { label: 'The web', kind: 'plain' },
      { label: 'Run commands', kind: 'plain' },
    ],
  },
  {
    who: 'Its research helper',
    note: 'The agent cuts it two',
    keys: [
      { label: 'Your files', kind: 'plain' },
      { label: 'The web', kind: 'plain' },
    ],
  },
  {
    who: 'The helper’s helper',
    note: 'One key. That’s all it will ever hold.',
    keys: [{ label: 'The web', kind: 'plain' }],
  },
];

const captions = [
  'Your agent wants help. Before it lifts a finger, you decide which keys it may copy.',
  'You cut it three copies. Your passwords aren’t one of them — no copy of that key exists outside your hand.',
  'It hires a helper and cuts the helper two. It cannot cut a key it doesn’t hold.',
  'The helper’s helper gets one. Down the whole chain, keys only ever get fewer — nothing below you can hold a key you don’t.',
];
---

<section class="keys" id="keys" data-keys-step="0" data-scene>
  <div class="keys-stage">
    <div class="wrap keys-grid">
      <div class="scene-copy prose">
        <p class="eyebrow">04 · the rules</p>
        <h2>It can’t take what<br />you didn’t give.</h2>
        <div class="keys-captions" aria-live="polite">
          {captions.map((c, i) => <p class="keys-caption" data-cap={i}>{c}</p>)}
        </div>
        <p class="keys-closer mono">
          not a promise in a prompt — the way the machine is built. Try it
          yourself, just below.
        </p>
      </div>

      <div class="keys-chain">
        {
          KEY_ROWS.map((row, i) => (
            <div class="keys-row" data-row={i} data-dock={i === 0 ? 'you' : undefined}>
              <p class="mono keys-who">{row.who}</p>
              <div class="keys-ring">
                {row.keys.map((k) => (
                  <span class={`key mono ${k.kind === 'held' ? 'key-held' : ''}`}>
                    <svg viewBox="0 0 24 12" width="20" height="10" aria-hidden="true">
                      <circle cx="5" cy="6" r="3.1" fill="none" stroke="currentColor" stroke-width="1.7" />
                      <rect x="9.6" y="5.2" width="6.2" height="1.7" rx="0.85" fill="currentColor" />
                      <rect x="17.4" y="5.2" width="3.4" height="1.7" rx="0.85" fill="currentColor" />
                      <rect x="14.2" y="6.9" width="1.7" height="3" rx="0.85" fill="currentColor" />
                    </svg>
                    {k.label}
                  </span>
                ))}
              </div>
              <p class="mono keys-note dim">{row.note}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* the pin: extra height is the scroll spent walking down the chain */
  .keys {
    position: relative;
    height: 320svh;
    border-top: 1px solid var(--line);
  }

  .keys-stage {
    position: sticky;
    top: 0;
    height: 100svh;
    display: grid;
    align-items: center;
    overflow: hidden;
  }

  .keys-grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: var(--s-6);
    align-items: center;
    width: 100%;
  }

  @media (max-width: 900px) {
    .keys-grid {
      grid-template-columns: 1fr;
      gap: var(--s-4);
    }
  }

  .scene-copy h2 {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-3);
  }

  /* one caption visible per step, cross-fading in place */
  .keys-captions {
    position: relative;
    min-height: 9em;
  }

  .keys-caption {
    position: absolute;
    inset: 0 auto auto 0;
    opacity: 0;
    translate: 0 0.6rem;
    transition: opacity var(--t-med) var(--ease-out), translate var(--t-med) var(--ease-out);
  }

  .keys[data-keys-step='0'] [data-cap='0'],
  .keys[data-keys-step='1'] [data-cap='1'],
  .keys[data-keys-step='2'] [data-cap='2'],
  .keys[data-keys-step='3'] [data-cap='3'] {
    opacity: 1;
    translate: 0 0;
  }

  .keys-closer {
    font-size: var(--step--1);
    color: var(--text-dim);
    opacity: 0;
    transition: opacity var(--t-med) var(--ease-out) 0.25s;
  }

  .keys[data-keys-step='3'] .keys-closer {
    opacity: 1;
  }

  .keys-chain {
    display: grid;
    gap: var(--s-3);
  }

  .keys-row {
    display: grid;
    gap: var(--s-1);
    padding: var(--s-3);
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--bg-raised);
    opacity: 0.18;
    translate: 0 1.2rem;
    transition:
      opacity var(--t-med) var(--ease-out),
      translate var(--t-med) var(--ease-out),
      border-color var(--t-med) var(--ease-out);
  }

  /* each catch lights one more level of the chain */
  .keys[data-keys-step='0'] [data-row='0'],
  .keys[data-keys-step='1'] [data-row='0'],
  .keys[data-keys-step='1'] [data-row='1'],
  .keys[data-keys-step='2'] [data-row='0'],
  .keys[data-keys-step='2'] [data-row='1'],
  .keys[data-keys-step='2'] [data-row='2'],
  .keys[data-keys-step='3'] .keys-row {
    opacity: 1;
    translate: 0 0;
    border-color: var(--line-bright);
  }

  .keys-who {
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    color: var(--text);
  }

  .keys-ring {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-1);
  }

  .key {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.35em 0.8em;
    border: 1px solid color-mix(in srgb, var(--bus) 45%, transparent);
    border-radius: 999px;
    color: var(--bus);
    font-size: 0.72rem;
    /* keys pop in a beat after their row lands */
    scale: 0.75;
    opacity: 0;
    transition: scale var(--t-med) var(--ease-out), opacity var(--t-med) var(--ease-out);
  }

  .keys[data-keys-step='0'] [data-row='0'] .key,
  .keys[data-keys-step='1'] :is([data-row='0'], [data-row='1']) .key,
  .keys[data-keys-step='2'] :is([data-row='0'], [data-row='1'], [data-row='2']) .key,
  .keys[data-keys-step='3'] .key {
    scale: 1;
    opacity: 1;
  }

  .key:nth-child(2) { transition-delay: 70ms; }
  .key:nth-child(3) { transition-delay: 140ms; }
  .key:nth-child(4) { transition-delay: 210ms; }

  /* the key that never leaves your hand */
  .key-held {
    color: var(--audit);
    border-color: color-mix(in srgb, var(--audit) 45%, transparent);
  }

  .keys-note {
    font-size: 0.72rem;
  }

  /* small screens and reduced motion get the finished chain, no pin: a
     100svh pinned stage can clip on phones, and the story still lands */
  @media (prefers-reduced-motion: reduce), (max-width: 900px) {
    .keys {
      height: auto;
      padding-block: var(--s-8);
    }

    .keys-stage {
      position: static;
      height: auto;
      overflow: visible;
    }

    .keys-row,
    .key,
    .keys-closer,
    .keys-caption {
      opacity: 1;
      translate: 0 0;
      scale: 1;
      position: static;
      transition: none;
    }

    .keys-captions {
      min-height: 0;
      display: grid;
      gap: var(--s-2);
    }
  }
</style>

<script>
  // Scroll position → step. rAF-throttled; one module-lifetime listener
  // (pages without the section simply never match). The transitions in CSS
  // supply the "catch": discrete steps, animated arrivals, fully reversible.
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  let queued = false;

  function onScroll(): void {
    if (queued || reduced) return;
    queued = true;
    requestAnimationFrame(() => {
      queued = false;
      const scene = document.getElementById('keys');
      if (!scene) return;
      const r = scene.getBoundingClientRect();
      const span = r.height - innerHeight;
      const p = span > 4 ? Math.min(1, Math.max(0, -r.top / span)) : 1;
      const step = p < 0.22 ? 0 : p < 0.48 ? 1 : p < 0.74 ? 2 : 3;
      if (scene.dataset.keysStep !== String(step)) scene.dataset.keysStep = String(step);
    });
  }
  addEventListener('scroll', onScroll, { passive: true });
  addEventListener('resize', onScroll, { passive: true });
  document.addEventListener('astro:page-load', onScroll);
</script>
