---
import { getEntry, render } from 'astro:content';
import Docs from '../../layouts/Docs.astro';
import { loadNav, flatNav } from '../../lib/docs-nav';

const entry = await getEntry('handbook', 'introduction');
if (!entry) throw new Error('astrid-handbook introduction.md not found');
const { Content, headings } = await render(entry);

const nav = loadNav('../../astrid-handbook');
const flat = flatNav(nav);
---

<Docs
  bookTitle="The Contributor Handbook"
  basePath="/handbook"
  title="Introduction"
  nav={nav}
  currentSlug="introduction"
  headings={headings}
  prev={undefined}
  next={flat[1]}
>
  <Content />
</Docs>
